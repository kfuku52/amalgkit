#! /usr/bin/env python

import os
import sys

SCRIPT_DIR = os.path.realpath(os.path.dirname(__file__))
SCRIPT_PARENT_DIR = os.path.realpath(os.path.dirname(SCRIPT_DIR))

cleaned_sys_path = []
for path_entry in sys.path:
    real_entry = os.path.realpath(path_entry if path_entry != '' else os.getcwd())
    if real_entry == SCRIPT_DIR:
        continue
    cleaned_sys_path.append(path_entry)
sys.path[:] = cleaned_sys_path
if SCRIPT_PARENT_DIR not in [os.path.realpath(path if path != '' else os.getcwd()) for path in sys.path]:
    sys.path.insert(0, SCRIPT_PARENT_DIR)

from amalgkit.cli_entry import main


if __name__ == '__main__':
    raise SystemExit(main())
